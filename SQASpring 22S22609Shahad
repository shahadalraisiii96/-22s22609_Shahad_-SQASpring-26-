#include <iostream>

using namespace std;

int main() {

    char choice;

    cout << "1. Sign-up\n";
    cout << "2. Login\n";
    cout << "Enter your choice: ";
    cin >> choice;

    // if-else statement
    if (choice == '1' || choice == '2') {
        cout << "Valid choice entered.\n";
    } else {
        cout << "Wrong choice entered.\n";
    }

    // Switch statement
    switch (choice) {

        case '1':
            cout << "Sign-up feature selected successfully.\n";
            break;

        case '2':
            cout << "Login feature selected successfully.\n";
            break;

        default:
            cout << "Invalid Option!\n";
            break;
    }

    return 0;
}
