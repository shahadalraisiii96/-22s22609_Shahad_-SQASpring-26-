#include <iostream>
#include <string>

using namespace std;

int main() {
    char choice;
    bool keepRunning = true;

    // A while loop keeps the menu alive until a valid choice or exit is made
    while (keepRunning) {
        cout << "\n--- Main Menu ---\n";
        cout << "1. Sign-up\n";
        cout << "2. Login\n";
        cout << "3. Exit\n";
        cout << "Enter your choice: ";
        cin >> choice;

        switch (choice) {
            case '1':
                cout << "Sign-up feature selected successfully.\n";
                keepRunning = false; // Breaks the loop after success
                break;

            case '2':
                cout << "Login feature selected successfully.\n";
                keepRunning = false; // Breaks the loop after success
                break;

            case '3':
                cout << "Exiting program. Goodbye!\n";
                keepRunning = false;
                break;

            default:
                cout << "Wrong choice entered. Please try again.\n";
                // loop continues
                break;
        }
    }

    return 0;
}
